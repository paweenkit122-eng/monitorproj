generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Monitoring {
  id        Int      @id @default(autoincrement())
  cpu       Float
  ram       Float
  disk      Float
  createdAt DateTime @default(now())
}